<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<title>Mycroclean - Offerta Cliente</title>
<style>
@page{size:A4;margin:0}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:Helvetica,Arial,sans-serif;color:#1B2A4A;font-size:9pt;background:#f0f4f8}
.page{width:210mm;min-height:297mm;background:#fff;margin:0 auto;position:relative;padding-bottom:20mm}
.header{background:#D6246E;padding:14px 20mm;display:flex;align-items:center;justify-content:space-between}
.header-left{display:flex;align-items:center;gap:14px}
.logo-img{width:48px;height:48px;border-radius:50%;background:#fff;padding:3px}
.company-name{color:#fff;font-size:18pt;font-weight:700}
.company-sub{color:#fff;font-size:9pt}
.company-desc{color:#ffcce0;font-size:7pt;margin-top:3px}
.badge{background:#fff;border-radius:6px;padding:8px 16px;text-align:center}
.badge-label{font-size:7pt;color:#D6246E;font-weight:700}
.badge-num{font-size:14pt;font-weight:700;color:#1B2A4A}
.meta-row{padding:12px 20mm 0;display:flex;gap:24px}
.meta-item .label{font-size:7pt;color:#6B7B8D;text-transform:uppercase}
.meta-item .value{font-size:9pt;font-weight:700;margin-top:2px}
.two-cols{margin:10px 20mm 0;display:flex;gap:12px}
.client-box{flex:1;background:#F0F4F8;border-radius:6px;padding:10px 14px;border-left:3px solid #D6246E}
.ref-box{flex:0 0 200px;background:#F0F4F8;border-radius:6px;padding:10px 14px;border-left:3px solid #1B2A4A}
.box-label{font-size:7pt;color:#6B7B8D;text-transform:uppercase}
.box-value{font-size:10pt;font-weight:700;margin-top:3px}
.box-sub{font-size:7.5pt;color:#6B7B8D;margin-top:2px}
.section{padding:10px 20mm 0}
.section-title{font-size:9pt;font-weight:700;display:inline-block;border-bottom:2px solid #D6246E;padding-bottom:2px;margin-bottom:8px}
.dot{display:inline-block;width:6px;height:6px;background:#D6246E;border-radius:50%;margin-right:6px;vertical-align:middle}
.subject-label{font-size:7pt;color:#6B7B8D;text-transform:uppercase}
.subject-text{font-size:8.5pt;line-height:1.5;margin-top:4px;white-space:pre-line}
table{width:100%;border-collapse:collapse;margin-top:4px}
thead th{background:#1B2A4A;color:#fff;font-size:6.5pt;padding:5px 6px;text-align:center;font-weight:700}
thead th:nth-child(2){text-align:left}
tbody td{padding:4px 6px;font-size:7.5pt;border-bottom:1px solid #D0D8E0;text-align:right}
tbody td:nth-child(2){text-align:left}
tbody tr:nth-child(even){background:#F0F4F8}
.total-row{background:#E8DCF0 !important;font-weight:700}
.total-row td{border-top:2px solid #D6246E;font-size:8pt}
.totals{text-align:right;padding:8px 20mm 0}
.totals-line{font-size:9pt;margin-bottom:3px}
.totals-line .lbl{color:#6B7B8D;margin-right:14px}
.grand-total{background:#D6246E;color:#fff;border-radius:6px;padding:8px 16px;display:inline-block;margin-top:6px;text-align:center}
.grand-total .lbl{font-size:7pt;color:#FFB0CC;font-weight:700}
.grand-total .val{font-size:13pt;font-weight:700;margin-top:2px}
.info-row{padding:6px 20mm 0;display:flex;gap:20px;font-size:8pt}
.info-item .il{color:#6B7B8D;font-size:7pt;text-transform:uppercase}
.info-item .iv{font-weight:700;margin-top:1px}
.notes li{font-size:7pt;line-height:1.9;list-style:none}
.notes li:before{content:"\2022";color:#D6246E;margin-right:8px;font-weight:700}
.signatures{padding:16px 20mm 0;display:flex;justify-content:space-between}
.sig-box{width:42%}
.sig-box .lbl{font-size:7pt;color:#6B7B8D}
.sig-line{border-top:1px solid #D0D8E0;margin-top:28px;padding-top:3px;font-size:6.5pt;color:#6B7B8D}
.certs{padding:10px 20mm 0;display:flex;align-items:center;gap:16px;justify-content:center}
.certs img{height:40px}
.footer{position:absolute;bottom:0;left:0;right:0}
.footer-line{border-top:2px solid #D6246E;margin:0 20mm}
.footer-text{text-align:center;padding:4px 0;font-size:6pt;color:#6B7B8D}
.footer-bar{background:#D6246E;padding:3px;text-align:center;color:#fff;font-size:5pt;font-weight:700;letter-spacing:2px}
.controls{text-align:center;padding:16px;background:#f0f4f8}
.btn{padding:12px 36px;background:#D6246E;color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;margin:4px}
.btn:hover{background:#c01e60}
.btn2{background:#1B2A4A}.btn2:hover{background:#0f1a30}
@media print{.controls{display:none}.page{margin:0;box-shadow:none}body{background:#fff}}
</style>
</head>
<body>
<div id="app"><div style="text-align:center;padding:60px;color:#6B7B8D">Caricamento...</div></div>
<script>
var LOGO="data:image/png;base64,";
var ACCREDIA="data:image/png;base64,";
var CERTIS="data:image/png;base64,";
var params=new URLSearchParams(window.location.search);
var dp=params.get('data');var offer=null;
if(dp){try{offer=JSON.parse(decodeURIComponent(dp))}catch(e){try{offer=JSON.parse(dp)}catch(e2){}}}
if(!offer){document.getElementById('app').innerHTML='<div class="controls" style="min-height:100vh;display:flex;align-items:center;justify-content:center"><div><img src="'+LOGO+'" style="width:60px;border-radius:50%;margin-bottom:16px"><h2 style="color:#1B2A4A;margin-bottom:8px">Offerta Cliente PDF</h2><p style="color:#6B7B8D;margin-bottom:16px">Incolla il JSON:</p><textarea id="ji" style="width:400px;height:200px;border:2px solid #d0d8e0;border-radius:8px;padding:10px;font-size:11px;font-family:monospace"></textarea><br><button class="btn" style="margin-top:10px" onclick="loadJ()">Carica</button></div></div>'}
else{render(offer)}
function loadJ(){try{offer=JSON.parse(document.getElementById('ji').value);render(offer)}catch(e){alert('JSON non valido')}}
function fD(d){if(!d)return'\u2014';try{return new Date(d).toLocaleDateString('it-IT',{day:'2-digit',month:'2-digit',year:'numeric'})}catch(e){return String(d)}}
function fC(v){var n=parseFloat(v);if(isNaN(n)||n===0)return'\u2014';return new Intl.NumberFormat('it-IT',{style:'currency',currency:'EUR'}).format(n)}
function render(o){
var righe=o.righe||[];var gT=0;var hasSconto=righe.some(function(r){return(r.sconto||0)>0});
var rowsHtml='';
righe.forEach(function(r,i){
var qty=r.quantita||0,pp=r.prezzo||0,sc=r.sconto||0;
var tot=qty*pp*(1-sc/100);gT+=tot;
rowsHtml+='<tr><td style="text-align:center">'+(i+1)+'</td><td>'+(r.descrizione||'')+'</td><td>'+(r.colore||'')+'</td><td>'+(r.taglia||'')+'</td><td>'+(qty||'')+'</td><td>'+fC(pp)+'</td>'+(hasSconto?'<td>'+(sc?sc+'%':'\u2014')+'</td>':'')+'<td style="font-weight:700">'+fC(tot)+'</td></tr>';
});
var iva=parseFloat(o.iva)||22;
var notesHtml='';var defaultNotes=['Tutti gli indumenti sono confezionati con cuciture a barriera.','Consegna: '+(o.consegna||'da concordare'),'Trasporto: '+(o.trasporto||'da concordare'),'Minimo d\'ordine per taglia: verificare disponibilit\u00e0.'];
if(o.note){o.note.split('\n').forEach(function(l){if(l.trim())defaultNotes.push(l.trim())})}
defaultNotes.forEach(function(n){notesHtml+='<li>'+n+'</li>'});
var refHtml='';
if(o.referente_nome){refHtml='<div class="ref-box"><div class="box-label">REFERENTE COMMERCIALE</div><div class="box-value">'+o.referente_nome+'</div>'+(o.referente_email?'<div class="box-sub">\u2709 '+o.referente_email+'</div>':'')+(o.telefono?'<div class="box-sub">\u260e '+o.telefono+'</div>':'')+'</div>'}
document.getElementById('app').innerHTML='<div class="controls"><button class="btn" onclick="window.print()">\ud83d\udda8\ufe0f Stampa / Salva PDF</button><button class="btn btn2" onclick="window.print()">Ctrl+P</button></div>'+
'<div class="page">'+
'<div class="header"><div class="header-left"><img class="logo-img" src="'+LOGO+'"><div><div class="company-name">MYCROCLEAN</div><div class="company-sub">ITALIA\u00ae</div><div class="company-desc">Indumenti per Clean Room | Made in Italy</div></div></div><div class="badge"><div class="badge-label">OFFERTA N\u00b0</div><div class="badge-num">'+(o.numero||'')+'</div></div></div>'+
'<div class="meta-row"><div class="meta-item"><div class="label">DATA OFFERTA</div><div class="value">'+fD(o.data)+'</div></div><div class="meta-item"><div class="label">VALIDIT\u00c0</div><div class="value">'+fD(o.validita)+'</div></div><div class="meta-item"><div class="label">PAGAMENTO</div><div class="value">'+(o.pagamento||'')+'</div></div></div>'+
'<div class="two-cols"><div class="client-box"><div class="box-label">DESTINATARIO</div><div class="box-value">'+(o.cliente||'')+'</div></div>'+refHtml+'</div>'+
(o.corpo?'<div class="section"><div class="dot"></div><span class="subject-label">OGGETTO</span><div class="subject-text">'+o.corpo+'</div></div>':'')+
'<div class="section"><table><thead><tr><th>#</th><th>Descrizione</th><th>Colore</th><th>Taglia</th><th>Qt\u00e0</th><th>Prezzo unit.</th>'+(hasSconto?'<th>Sc%</th>':'')+'<th>Totale</th></tr></thead><tbody>'+rowsHtml+'<tr class="total-row"><td colspan="'+(hasSconto?6:5)+'"></td><td>TOTALE</td><td>'+fC(gT)+'</td></tr></tbody></table></div>'+
'<div class="info-row"><div class="info-item"><div class="il">Consegna</div><div class="iv">'+(o.consegna||'\u2014')+'</div></div><div class="info-item"><div class="il">Trasporto</div><div class="iv">'+(o.trasporto||'\u2014')+'</div></div></div>'+
'<div class="totals"><div class="totals-line"><span class="lbl">Imponibile</span><span>'+fC(gT)+'</span></div><div class="totals-line"><span class="lbl">IVA ('+iva+'%)</span><span>'+fC(gT*iva/100)+'</span></div><div class="grand-total"><div class="lbl">TOTALE OFFERTA</div><div class="val">'+fC(gT*(1+iva/100))+'</div></div></div>'+
'<div class="section"><div class="dot"></div><span class="section-title">NOTE E CONDIZIONI</span><ul class="notes">'+notesHtml+'</ul></div>'+
'<div class="signatures"><div class="sig-box"><div class="lbl">Per accettazione del fornitore</div><div class="sig-line">Firma e timbro</div></div><div class="sig-box"><div class="lbl">Per accettazione del cliente</div><div class="sig-line">Firma e timbro</div></div></div>'+
'<div class="certs"><img src="'+ACCREDIA+'"><img src="'+CERTIS+'"></div>'+
'<div class="footer"><div class="footer-line"></div><div class="footer-text">Mycroclean Italia\u00ae | Tel. 02 95300368 | info@mycroclean.it | Indumenti Clean Room</div><div class="footer-bar">MYCROCLEAN ITALIA\u00ae</div></div>'+
'</div>';
}
</script>
</body>
</html>
